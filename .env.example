# Copy this file to .env and fill in your real keys.
# .env is gitignored — never commit real keys.

# Anthropic Claude
# Get key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key-here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Google Gemini
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-2.5-pro

# DeepSeek (OpenAI-compatible)
# Get key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your-deepseek-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Zhipu GLM (OpenAI-compatible) - recommended fallback for mainland China users
# Get key: https://bigmodel.cn/usercenter/proj-mgmt/apikeys (20M free tokens on signup)
ZHIPU_API_KEY=your-zhipu-key-here
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4.6
